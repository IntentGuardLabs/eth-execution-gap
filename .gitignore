# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# private — internal docs and intermediate artifacts kept locally only
/blueprints/
/specs/
/reports/
/.claude/
CLAUDE.md
AGENTS.md
graphify-out/
.graphifyignore

# CLI output — local cache and run reports
/.cache/
/data/
/tests/

# legacy web-app artifacts (preserved on the web-app branch only)
/app/
/prisma/
/public/
Dockerfile
docker-compose.yml
next.config.ts
postcss.config.mjs
