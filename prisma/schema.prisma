// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model WalletAnalysis {
  id              String    @id @default(cuid())
  address         String    @unique
  totalLossUsd    Float
  sandwichLossUsd Float
  delayLossUsd    Float
  slippageLossUsd Float
  txsAnalyzed     Int
  txsSandwiched   Int
  worstTxHash     String?
  worstTxLossUsd  Float?
  avgDelayMs      Int?
  rank            Int?
  analyzedAt      DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  transactions    TransactionAnalysis[]
  etherscanTxs    EtherscanTxRaw[]
  duneMempools    DuneMempoolRaw[]

  @@index([totalLossUsd])
  @@index([address])
}

model EtherscanTxRaw {
  id                  String   @id @default(cuid())
  walletAnalysisId    String
  walletAnalysis      WalletAnalysis @relation(fields: [walletAnalysisId], references: [id], onDelete: Cascade)
  txHash              String
  from                String
  to                  String
  value               String
  input               String
  gas                 String
  gasPrice            String
  gasUsed             String?
  blockNumber         Int
  blockHash           String?
  transactionIndex    Int
  isError             String
  txreceipt_status    String?
  timeStamp           String
  fetchedAt           DateTime @default(now())

  @@index([walletAnalysisId])
  @@index([txHash])
  @@index([blockNumber])
}

model DuneMempoolRaw {
  id                  String   @id @default(cuid())
  walletAnalysisId    String
  walletAnalysis      WalletAnalysis @relation(fields: [walletAnalysisId], references: [id], onDelete: Cascade)
  txHash              String
  blockNumber         Int
  mempoolBlockNumber  Int?
  inclusionDelayMs    Int?
  queryResult         String
  queriedAt           DateTime @default(now())

  @@index([walletAnalysisId])
  @@index([txHash])
  @@index([blockNumber])
}

model TenderlySimulationRaw {
  id                  String   @id @default(cuid())
  txHash              String
  blockNumber         Int
  from                String
  to                  String
  input               String
  value               String
  gas                 String
  gasPrice            String
  simulationResult    String
  simulatedAt         DateTime @default(now())

  @@unique([txHash, blockNumber])
  @@index([txHash])
  @@index([blockNumber])
}

model TransactionAnalysis {
  id                  String   @id @default(cuid())
  walletAnalysisId    String
  walletAnalysis      WalletAnalysis @relation(fields: [walletAnalysisId], references: [id], onDelete: Cascade)
  txHash              String   @unique
  blockNumber         Int
  mempoolBlockNumber  Int?
  inclusionDelayMs    Int?
  expectedOutputRaw   String   // BigInt as string
  actualOutputRaw     String   // BigInt as string
  tokenAddress        String
  tokenSymbol         String?
  tokenDecimals       Int?     // HR-8: actual decimals from Tenderly token_info
  gapRaw              String   // BigInt as string
  gapUsd              Float
  gapType             String   // "sandwich" | "delay" | "slippage"
  isSandwiched        Boolean  @default(false)
  sandwichBotAddress  String?
  frontrunTxHash      String?
  backrunTxHash       String?
  isEstimated         Boolean  @default(false) // true if mempool timing was fallback
  contractAddress     String?  // Protocol address for aggregation
  createdAt           DateTime @default(now())

  @@index([walletAnalysisId])
  @@index([txHash])
  @@index([contractAddress])
}

model AnalysisJob {
  id          String   @id @default(cuid())
  address     String
  status      String   @default("pending") // pending | fetching_txs | filtering | querying_mempool | simulating | calculating | complete | error
  progress    Int      @default(0)         // 0-100
  totalTxs    Int?
  processedTxs Int?
  error       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  @@index([address])
}
