# Copy to `.env` and fill in.
# Free-tier accounts are sufficient for normal CLI usage.

# Etherscan v2 API key — required by `tx:run` and `wallet:run`.
# Used to fetch transaction details and wallet history.
# Sign up: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# Dune Analytics API key — required by `wallet:run` and `protocol:run`.
# Optional for `tx:run` (only used to log mempool-arrival metadata).
# Sign up: https://dune.com/settings/api
DUNE_API_KEY=

# Tenderly account/project/key — required by all three commands.
# Sign up: https://tenderly.co/  →  Settings → Authorization
TENDERLY_ACCOUNT=
TENDERLY_PROJECT=
TENDERLY_API_KEY=

# Optional — override the local cache directory. Default: .cache
# CLI_CACHE_DIR=.cache
